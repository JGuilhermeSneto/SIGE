# Configurações do Django
SECRET_KEY=sua-chave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
# Em produção, use o domínio público do site e defina DEBUG=False

# Segurança em produção
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# CORS_ALLOWED_ORIGINS=https://meusite.com
# CSRF_TRUSTED_ORIGINS=https://meusite.com
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Vite (dev): URL do ``npm run dev`` — usada em ``app_vite.html`` para carregar o React
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173

# Banco de Dados (Padrão SQLite se DB_ENGINE não for definido)
# Para usar MySQL:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=nome_do_banco
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha
# DB_HOST=localhost
# DB_PORT=3306

# Configurações de E-mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
