
[flake8]
max-line-length = 120
extend-ignore = E203, W503
# Erros que devem ser capturados para manter a qualidade
select = B,C,E,F,W,T4,B9

exclude =
    migrations,
    __pycache__,
    manage.py,
    venv,
    .venv,
    .git,
    *.pot,
    *.pyc,
    config/settings.py

# Ignorar apenas em casos específicos onde o Django/Simple-History geram código
per-file-ignores =
    */__init__.py: F401, F403
    apps/usuarios/models/perfis.py: E402