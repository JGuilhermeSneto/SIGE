# =============================================================================
# SIGE — modelo de .env (copie para .env e preencha os valores)
# cp .env.example .env
# =============================================================================

# --- Django ---
SECRET_KEY=gere-uma-chave-secreta-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,seu-app.onrender.com

# --- Frontend (Vite/React) ---
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://seu-app.onrender.com

# --- Banco de dados ---
DATABASE_URL=mysql://usuario:senha@host:3306/nome_db?ssl-mode=REQUIRED
# DATABASE_URL=sqlite:///db.sqlite3

# --- Redis / Celery ---
USE_REDIS=False
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# --- Cloudinary (deixe vazio para usar pasta media/ local) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SERVE_MEDIA_FILES=True

# --- E-mail (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=seu-email@gmail.com

# --- Segurança ---
SEGURANCA_IP_WHITELIST=127.0.0.1,::1
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# --- Observabilidade ---
SENTRY_DSN=

# --- Monitoramento Celery ---
FLOWER_URL=http://localhost:5555

# --- Integrações futuras ---
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
